generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. Core Identity & Tenancy
// ==========================================

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users            User[]
  apiKeys          ApiKey[]
  resumeUploads    ResumeUpload[]
  wallet           Wallet?
  subscriptions    Subscription[]
  payments         Payment[]
  invoices         Invoice[]
  clientUsageLogs  ClientUsageLog[]
  billingHistories BillingHistory[]

  @@index([name])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // ADMIN, MANAGER, USER
  permissions Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String? // If using email/password
  image         String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  sessions Session[]
  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([roleId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. Core Application (Resume Parsing)
// ==========================================

model ResumeUpload {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fileName String
  fileUrl  String?
  rawText  String?      @db.LongText
  status   UploadStatus @default(PENDING) // PENDING, PROCESSING, COMPLETED, FAILED
  error    String?      @db.Text

  parsedResult ParsedResult?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ParsedResult {
  id             String       @id @default(uuid())
  resumeUploadId String       @unique
  resumeUpload   ResumeUpload @relation(fields: [resumeUploadId], references: [id], onDelete: Cascade)

  data         Json // The parsed resume JSON
  rawResponse  Json? // Raw AI provider output
  modelUsed    String? // Which provider model was used
  tokensUsed   Int? // How many tokens it cost

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeUploadId])
}

// ==========================================
// 3. API Provisioning
// ==========================================

model ApiKey {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name       String
  key        String    @unique
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  usageLogs ClientUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([key])
}

model ClientUsageLog {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  endpoint    String
  creditsUsed Float

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([apiKeyId])
  @@index([createdAt])
}

// ==========================================
// 4. Subscriptions & Wallets
// ==========================================

model Plan {
  id       String @id @default(uuid())
  name     String @unique // e.g. Free, Pro, Enterprise
  price    Float
  currency String @default("INR")
  credits  Int    @default(0)
  features Json?
  isActive Boolean @default(true)

  subscriptions Subscription[]
  payments      Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  status            SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd  DateTime
  cancelAtPeriodEnd Boolean            @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([planId])
  @@index([status])
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIAL
}

model Wallet {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  balance  Float  @default(0.0)
  currency String @default("USD")

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  creditsBefore Float
  creditsUsed   Float
  creditsAfter  Float

  type        TransactionType // CREDIT, DEBIT
  action      String
  description String?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([createdAt])
}

enum TransactionType {
  CREDIT
  DEBIT
}

model Payment {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId            String?
  plan              Plan?   @relation(fields: [planId], references: [id])

  amount            Float
  currency          String        @default("INR")
  status            PaymentStatus @default(PENDING)
  
  razorpayOrderId   String?       @unique 
  razorpayPaymentId String?       @unique
  razorpaySignature String?       @db.Text

  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([razorpayOrderId])
  @@index([planId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Invoice {
  id        String  @id @default(uuid())
  paymentId String  @unique
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pdfUrl        String?
  invoiceNumber String  @unique

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([invoiceNumber])
}

model BillingHistory {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  action  String // e.g. "SUBSCRIPTION_RENEWED", "CREDIT_ADDED"
  details Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
}

// ==========================================
// 5. AI Providers System Layer
// ==========================================

model ApiProvider {
  id       String  @id @default(uuid())
  name     String  @unique // e.g. "OpenAI", "Gemini", "DeepSeek"
  isActive Boolean @default(true)

  accounts   ProviderAccount[]
  models     ProviderModel[]
  rateLimits ProviderRateLimit[]
  usageLogs  ProviderUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderAccount {
  id         String      @id @default(uuid())
  providerId String
  provider   ApiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  name            String // "System Account 1"
  isActive        Boolean @default(true)
  
  apiKeys         ProviderApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
}

model ProviderApiKey {
  id                String          @id @default(uuid())
  providerAccountId String
  account           ProviderAccount @relation(fields: [providerAccountId], references: [id], onDelete: Cascade)

  keyEncrypted      String          @db.Text
  isActive          Boolean         @default(true)
  priority          Int             @default(0) // Higher number = used first

  limitRequestsDaily  Int?
  limitRequestsPerMin Int?
  limitRequestsPerHour Int?
  limitRequestsPerMonth Int?

  usageCountDaily     Int             @default(0)
  usageCountMin       Int             @default(0)
  usageCountHour      Int             @default(0)
  usageCountMonth     Int             @default(0)
  isExhausted         Boolean         @default(false)
  exhaustedResetAt    DateTime?
  lastUsedAt          DateTime?

  usageLogs         ProviderUsageLog[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([providerAccountId])
}

model ProviderModel {
  id         String      @id @default(uuid())
  providerId String
  provider   ApiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  modelName          String // "gpt-4o", "gemini-1.5-pro"
  costPer1kTokensIn  Float  @default(0.0)
  costPer1kTokensOut Float  @default(0.0)
  
  costPerRequest     Float  @default(0.0)
  maxRequestsPerMin  Int?
  maxDailyLimit      Int?
  tokenLimit         Int?

  isActive           Boolean @default(true)

  usageLogs ProviderUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, modelName])
  @@index([providerId])
}

model ProviderRateLimit {
  id         String      @id @default(uuid())
  providerId String
  provider   ApiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  limitPerMin  Int
  tokensPerMin Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
}

model ProviderUsageLog {
  id         String      @id @default(uuid())
  providerId String
  provider   ApiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  modelId       String
  providerModel ProviderModel @relation(fields: [modelId], references: [id])

  apiKeyId      String?
  apiKey        ProviderApiKey? @relation(fields: [apiKeyId], references: [id])

  tokensIn  Int
  tokensOut Int
  totalCost Float

  requestTimeMs Int?
  isError       Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([providerId])
  @@index([modelId])
  @@index([apiKeyId])
  @@index([createdAt])
}

// ==========================================
// 6. Audit Logging
// ==========================================

model AdminLog {
  id      String @id @default(uuid())
  adminId String // Intentionally not a strict relation to User to preserve logs if user is deleted
  action  String // "UPDATED_PLAN_PRICE", "DEACTIVATED_TENANT"
  details Json?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}
